// Omero Finance — Prisma Schema v1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users             User[]
  incomes           Income[]
  creditCards       CreditCardStatement[]
  fixedExpenses     FixedExpense[]
  groceries         GroceryExpense[]
  householdExpenses HouseholdExpense[]
  personalExpenses  PersonalExpense[]
  rentPayments      RentPayment[]
  savings           Saving[]
  loans             Loan[]
  debts             Debt[]
  mpMovements       MercadoPagoMovement[]
  budgetConfigs     BudgetConfig[]
  exchangeRates     ExchangeRate[]
}

model User {
  id           String   @id @default(cuid())
  householdId  String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)
  avatarColor  String   @default("#6366F1")
  createdAt    DateTime @default(now())

  household               Household             @relation(fields: [householdId], references: [id])
  sessions                Session[]
  incomesCreated          Income[]              @relation("IncomeCreatedBy")
  creditCardsCreated      CreditCardStatement[] @relation("CardCreatedBy")
  fixedExpensesCreated    FixedExpense[]        @relation("FixedCreatedBy")
  groceriesCreated        GroceryExpense[]      @relation("GroceryCreatedBy")
  householdExpCreated     HouseholdExpense[]    @relation("HouseholdExpCreatedBy")
  personalExpOwned        PersonalExpense[]     @relation("PersonalExpOwner")
  personalExpCreated      PersonalExpense[]     @relation("PersonalExpCreatedBy")
  rentCreated             RentPayment[]         @relation("RentCreatedBy")
  savingsCreated          Saving[]              @relation("SavingCreatedBy")
  loansOwned              Loan[]                @relation("LoanOwner")
  loansCreated            Loan[]                @relation("LoanCreatedBy")
  debtsCreated            Debt[]                @relation("DebtCreatedBy")
  mpMovementsCategorized  MercadoPagoMovement[] @relation("MPCategorizedBy")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Income
// ─────────────────────────────────────────────

model Income {
  id                 String     @id @default(cuid())
  householdId        String
  createdById        String
  month              String
  year               Int
  type               IncomeType
  currency           Currency   @default(ARS)
  amount             Decimal    @db.Decimal(14, 2)
  amountArs          Decimal?   @db.Decimal(14, 2)
  dollarRateSnapshot Decimal?   @db.Decimal(10, 4)
  description        String?
  createdAt          DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("IncomeCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Credit Cards
// ─────────────────────────────────────────────

model CreditCardStatement {
  id                 String   @id @default(cuid())
  householdId        String
  createdById        String
  month              String
  year               Int
  cardName           String
  ownerUserId        String?
  dueDate            DateTime
  minimumPayment     Decimal? @db.Decimal(14, 2)
  totalAmountArs     Decimal  @db.Decimal(14, 2)
  usdAmount          Decimal? @db.Decimal(14, 2)
  dollarRateSnapshot Decimal? @db.Decimal(10, 4)
  customAmount       Decimal? @db.Decimal(14, 2)
  amountToPay        Decimal  @db.Decimal(14, 2)
  payMinimum         Boolean  @default(false)
  isPaid             Boolean  @default(false)
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("CardCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Fixed Expenses
// ─────────────────────────────────────────────

model FixedExpense {
  id                 String   @id @default(cuid())
  householdId        String
  createdById        String
  concept            String
  subcategory        String?
  currency           Currency @default(ARS)
  amount             Decimal  @db.Decimal(14, 2)
  amountArs          Decimal? @db.Decimal(14, 2)
  dollarRateSnapshot Decimal? @db.Decimal(10, 4)
  isPaid             Boolean  @default(false)
  month              String
  year               Int
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("FixedCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Grocery Expenses
// ─────────────────────────────────────────────

model GroceryExpense {
  id                 String   @id @default(cuid())
  householdId        String
  createdById        String
  month              String
  year               Int
  description        String
  cardName           String?
  currency           Currency @default(ARS)
  amount             Decimal  @db.Decimal(14, 2)
  amountArs          Decimal? @db.Decimal(14, 2)
  dollarRateSnapshot Decimal? @db.Decimal(10, 4)
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("GroceryCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Household General Expenses
// ─────────────────────────────────────────────

model HouseholdExpense {
  id                 String      @id @default(cuid())
  householdId        String
  createdById        String
  month              String
  year               Int
  description        String
  cardName           String?
  expenseType        ExpenseType @default(UNNECESSARY)
  currency           Currency    @default(ARS)
  amount             Decimal     @db.Decimal(14, 2)
  amountArs          Decimal?    @db.Decimal(14, 2)
  dollarRateSnapshot Decimal?    @db.Decimal(10, 4)
  createdAt          DateTime    @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("HouseholdExpCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Personal Expenses
// ─────────────────────────────────────────────

model PersonalExpense {
  id                 String   @id @default(cuid())
  householdId        String
  userId             String
  createdById        String
  month              String
  year               Int
  concept            String
  cardName           String?
  currency           Currency @default(ARS)
  amount             Decimal  @db.Decimal(14, 2)
  amountArs          Decimal? @db.Decimal(14, 2)
  dollarRateSnapshot Decimal? @db.Decimal(10, 4)
  isPaid             Boolean  @default(true)
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  owner     User      @relation("PersonalExpOwner", fields: [userId], references: [id])
  createdBy User      @relation("PersonalExpCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Rent & Building Fees
// ─────────────────────────────────────────────

model RentPayment {
  id                 String   @id @default(cuid())
  householdId        String
  createdById        String
  month              String
  year               Int
  type               RentType
  apartment          String
  currency           Currency @default(ARS)
  amount             Decimal  @db.Decimal(14, 2)
  amountArs          Decimal? @db.Decimal(14, 2)
  dollarRateSnapshot Decimal? @db.Decimal(10, 4)
  description        String?
  cbuAlias           String?
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("RentCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Savings & Investments
// ─────────────────────────────────────────────

model Saving {
  id                 String     @id @default(cuid())
  householdId        String
  createdById        String
  date               DateTime
  description        String
  type               SavingType
  currency           Currency   @default(ARS)
  amount             Decimal    @db.Decimal(14, 2)
  amountArs          Decimal?   @db.Decimal(14, 2)
  dollarRateSnapshot Decimal?   @db.Decimal(10, 4)
  platform           String?
  createdAt          DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("SavingCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// Loans
// ─────────────────────────────────────────────

model Loan {
  id                 String          @id @default(cuid())
  householdId        String
  ownerUserId        String
  createdById        String
  direction          LoanDirection
  counterpart        String
  paymentMethod      String?
  currency           Currency        @default(ARS)
  principal          Decimal         @db.Decimal(14, 2)
  principalArs       Decimal?        @db.Decimal(14, 2)
  dollarRateSnapshot Decimal?        @db.Decimal(10, 4)
  installments       Int
  installmentUnit    InstallmentUnit @default(MONTHLY)
  interestRate       Decimal         @db.Decimal(6, 4)
  totalAmount        Decimal         @db.Decimal(14, 2)
  notes              String?
  createdAt          DateTime        @default(now())

  household          Household        @relation(fields: [householdId], references: [id])
  owner              User             @relation("LoanOwner", fields: [ownerUserId], references: [id])
  createdBy          User             @relation("LoanCreatedBy", fields: [createdById], references: [id])
  installmentRecords LoanInstallment[]
}

model LoanInstallment {
  id                String   @id @default(cuid())
  loanId            String
  installmentNumber Int
  dueDate           DateTime
  amount            Decimal  @db.Decimal(14, 2)
  currency          Currency @default(ARS)
  isPaid            Boolean  @default(false)
  paidDate          DateTime?

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Debts to collect
// ─────────────────────────────────────────────

model Debt {
  id                 String     @id @default(cuid())
  householdId        String
  createdById        String
  date               DateTime
  concept            String
  debtor             String
  currency           Currency   @default(ARS)
  totalAmount        Decimal    @db.Decimal(14, 2)
  totalArs           Decimal?   @db.Decimal(14, 2)
  dollarRateSnapshot Decimal?   @db.Decimal(10, 4)
  amountPaid         Decimal    @default(0) @db.Decimal(14, 2)
  status             DebtStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation("DebtCreatedBy", fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// MercadoPago
// ─────────────────────────────────────────────

model MercadoPagoMovement {
  id              String           @id @default(cuid())
  householdId     String
  mpReferenceId   String           @unique
  releaseDate     DateTime
  transactionType String
  netAmount       Decimal          @db.Decimal(14, 2)
  partialBalance  Decimal?         @db.Decimal(14, 2)
  currency        Currency         @default(ARS)
  status          MPMovementStatus @default(PENDING)
  category        String?
  subCategory     String?
  linkedExpenseId String?
  notes           String?
  categorizedById String?
  syncedAt        DateTime         @default(now())

  household     Household @relation(fields: [householdId], references: [id])
  categorizedBy User?     @relation("MPCategorizedBy", fields: [categorizedById], references: [id])
}

// ─────────────────────────────────────────────
// Budget Config
// ─────────────────────────────────────────────

model BudgetConfig {
  id               String         @id @default(cuid())
  householdId      String
  month            String
  year             Int
  category         BudgetCategory
  manualPercentage Decimal?       @db.Decimal(6, 4)
  manualAmount     Decimal?       @db.Decimal(14, 2)
  manualCurrency   Currency       @default(ARS)
  isReserved       Boolean        @default(true)

  household Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, month, year, category])
}

// ─────────────────────────────────────────────
// Exchange Rate
// ─────────────────────────────────────────────

model ExchangeRate {
  id          String     @id @default(cuid())
  householdId String?
  date        DateTime   @unique
  usdArs      Decimal    @db.Decimal(10, 4)
  source      RateSource @default(API)

  household Household? @relation(fields: [householdId], references: [id])
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MEMBER
}

enum Currency {
  ARS
  USD
}

enum IncomeType {
  SUELDO
  FREELANCE
  AHORROS
  PAGO_DEUDA
  REMANENTES
  PRESTAMO
  INVERSION
}

enum ExpenseType {
  NECESSARY
  UNNECESSARY
}

enum RentType {
  ALQUILER
  EXPENSAS
  TRABAJOS
}

enum SavingType {
  AHORRO
  VIAJE
  INVERSION
}

enum LoanDirection {
  DADO
  TOMADO
}

enum InstallmentUnit {
  WEEKLY
  MONTHLY
}

enum DebtStatus {
  ACTIVE
  SETTLED
}

enum MPMovementStatus {
  PENDING
  CATEGORIZED
}

enum BudgetCategory {
  ALQUILER
  TDC
  GASTOS_FIJOS
  MERCADO
  GASTOS_LIBRES
  AHORRO_CASA
  AHORRO_VACACIONES
  INVERSION_AHORRO
  OTROS
}

enum RateSource {
  API
  MANUAL
}
