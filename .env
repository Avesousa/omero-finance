# ─────────────────────────────────────────────
# Omero Finance — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Neon PostgreSQL (get from neon.tech dashboard)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="replace-with-random-secret"   # generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Exchange rate API (Bluelytics — no key needed for public endpoint)
BLUELYTICS_URL="https://api.bluelytics.com.ar/v2/latest"

# MercadoPago (OAuth, fill after MP app creation)
MP_ACCESS_TOKEN=""
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""

# AI voice parsing (choose one)
OPENAI_API_KEY=""        # for Whisper + GPT-4o mini
# ANTHROPIC_API_KEY=""   # for Claude Haiku
